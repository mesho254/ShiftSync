{
    "version": 2,
    "routes": [
        {
            "src": "/uploads/(.*)",
            "dest": "/uploads/$1",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/(.*)",
            "dest": "index.js"
        }
    ],
    "functions": {
        "index.js": {
            "maxDuration": 30
        }
    }
}